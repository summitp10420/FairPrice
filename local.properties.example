# Copy to local.properties and fill in your values.
# local.properties is gitignored and should not be committed.

# Supabase (required for app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Railway strategy engine (Part B)
RAILWAY_STRATEGY_ENDPOINT=https://your-railway-domain.up.railway.app/api/v1/strategy
